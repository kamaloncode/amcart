{
    "ReverseProxy": {
        "Routes": {
            "authRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/api/auth/{**catch-all}"
                }
            },
            "productRoute": {
                "ClusterId": "productCluster",
                "Match": {
                    "Path": "/api/product/{**catch-all}"
                }
            },
            "cartRoute": {
                "ClusterId": "cartCluster",
                "Match": {
                    "Path": "/api/cart/{**catch-all}"
                }
            },
            "orderRoute": {
                "ClusterId": "orderCluster",
                "Match": {
                    "Path": "/api/order/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "authCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://amcart-1.onrender.com/"
                    }
                }
            },
            "productCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://productservice-hcr6.onrender.com/"
                    }
                }
            },
            "cartCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://cartservice-i67a.onrender.com/"
                    }
                }
            },
            "orderCluster": {
                "Destinations": {
                    "d1": {
                        "Address": "https://orderservice-9kob.onrender.com/"
                    }
                }
            }
        }
    }
}