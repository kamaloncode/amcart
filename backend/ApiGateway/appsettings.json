{
    "ReverseProxy": {
        "Routes": {
            "authRoute": {
                "ClusterId": "authCluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/auth" }
                ]
            },
            "productRoute": {
                "ClusterId": "productCluster",
                "Match": {
                    "Path": "/product/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/product" }
                ],
                "AuthorizationPolicy": "default"
            },
            "cartRoute": {
                "ClusterId": "cartCluster",
                "Match": {
                    "Path": "/cart/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/cart" }
                ],
                "AuthorizationPolicy": "default"
            },
            "orderRoute": {
                "ClusterId": "orderCluster",
                "Match": {
                    "Path": "/order/{**catch-all}"
                },
                "Transforms": [
                    { "PathRemovePrefix": "/order" }
                ],
                "AuthorizationPolicy": "default"
            }
        },
        "Clusters": {
            "authCluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "https://localhost:7129/"
                    }
                }
            },
            "productCluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://localhost:5226/"
                    }
                }
            },
            "cartCluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://localhost:5117/"
                    }
                }
            },
            "orderCluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://localhost:5067/"
                    }
                }
            }
        }
    }    
}